{
  "name": "@opentalk/mattermost-plugin-webapp",
  "version": "0.0.2",
  "private": true,
  "scripts": {
    "build": "webpack --mode=production",
    "build:watch": "webpack --mode=production --watch",
    "debug": "webpack --mode=none",
    "debug:watch": "webpack --mode=development --watch",
    "lint": "eslint --ignore-pattern node_modules --ignore-pattern dist --ext=.js,.jsx,tsx,ts . --quiet --cache",
    "fix": "eslint --ignore-pattern node_modules --ignore-pattern dist --ext=.js,.jsx,tsx,ts . --quiet --fix --cache",
    "test": "jest --forceExit --detectOpenHandles --verbose",
    "test:watch": "jest --watch",
    "test-ci": "jest --forceExit --detectOpenHandles --maxWorkers=2",
    "check-types": "tsc"
  },
  "devDependencies": {
    "@babel/cli": "7.28.6",
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.5",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@babel/runtime": "7.29.2",
    "@emotion/babel-preset-css-prop": "11.12.0",
    "@emotion/react": "11.14.0",
    "@mattermost/client": "11.6.0",
    "@mattermost/eslint-plugin": "1.1.0-0",
    "@mattermost/types": "11.6.0",
    "@testing-library/jest-dom": "5.16.1",
    "@testing-library/react": "^16.3.2",
    "@types/babel__core": "7.20.5",
    "@types/babel__template": "7.4.4",
    "@types/jest": "30.0.0",
    "@types/node": "20.17.6",
    "@types/react": "18.2.64",
    "@types/react-dom": "^18.2.0",
    "@types/react-redux": "7.1.34",
    "@types/react-router-dom": "5.3.3",
    "@types/react-transition-group": "4.4.12",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "babel-loader": "10.1.1",
    "babel-plugin-formatjs": "10.3.7",
    "babel-plugin-typescript-to-proptypes": "2.1.0",
    "css-loader": "7.1.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "file-loader": "6.2.0",
    "identity-obj-proxy": "3.0.0",
    "isomorphic-fetch": "3.0.0",
    "jest": "30.4.2",
    "jest-canvas-mock": "2.5.2",
    "jest-environment-jsdom": "30.4.1",
    "jest-junit": "13.0.0",
    "react-dom": "18.2.0",
    "sass": "1.99.0",
    "sass-loader": "13.0.0",
    "style-loader": "3.3.1",
    "webpack": "5.106.2",
    "webpack-cli": "7.0.2"
  },
  "dependencies": {
    "camelcase-keys": "^7.0.2",
    "core-js": "3.49.0",
    "livekit-client": "^2.18.9",
    "mattermost-redux": "11.6.0",
    "mitt": "^3.0.1",
    "react": "18.2.0",
    "react-redux": "9.2.0",
    "redux": "5.0.1",
    "snakecase-keys": "^5.5.0",
    "typescript": "5.9.3"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/non_npm_dependencies/"
    ],
    "clearMocks": true,
    "collectCoverageFrom": [
      "src/**/*.{js,jsx}"
    ],
    "coverageReporters": [
      "lcov",
      "text-summary"
    ],
    "moduleNameMapper": {
      "^.+\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga|ogg)$": "identity-obj-proxy",
      "^.+\\.(css|less|scss)$": "identity-obj-proxy",
      "^.*i18n.*\\.(json)$": "<rootDir>/tests/i18n_mock.json",
      "^bundle-loader\\?lazy\\!(.*)$": "$1"
    },
    "moduleDirectories": [
      "src",
      "node_modules",
      "non_npm_dependencies"
    ],
    "reporters": [
      "default",
      "jest-junit"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!react-native|react-router|mattermost-webapp)"
    ],
    "setupFiles": [
      "jest-canvas-mock"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.tsx"
    ],
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "url": "http://localhost:8065"
    }
  },
  "overrides": {
    "@mattermost/eslint-plugin": {
      "eslint-plugin-react-hooks": "$eslint-plugin-react-hooks"
    }
  }
}
